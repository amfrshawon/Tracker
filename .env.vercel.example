# Required
DATABASE_URL="postgresql://<runtime-pooled-url>"
DIRECT_URL="postgresql://<direct-url-for-migrations>"
AUTH_SECRET="<replace-with-random-32+-char-secret>"
AUTH_URL="https://<your-vercel-domain>"
